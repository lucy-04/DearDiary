# Server
PORT=5001
# Set to "production" when hosting. Enables stricter logging and a JWT_SECRET check.
NODE_ENV=development
# Only needed if the frontend is hosted on a DIFFERENT origin than the API.
# Comma-separated list, e.g. https://diary.yoursite.com
# CLIENT_ORIGIN=

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Database (PostgreSQL / CockroachDB)
# Replace with your real connection string. Until then the server still boots,
# but anything that touches the database will return an error.
DATABASE_URL=postgresql://username:password@localhost:26257/diary_app?sslmode=disable

# Gemini API (used for emotion classification)
# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
